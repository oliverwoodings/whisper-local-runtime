# whisper.cpp source and build settings
WHISPER_REPO_URL=https://github.com/ggml-org/whisper.cpp.git
WHISPER_REPO_REF=main
WHISPER_SRC_DIR=./whisper/whisper.cpp-src
WHISPER_BUILD_DIR=./whisper/build

# Model settings
# Example model names: tiny.en, base.en, small.en, medium.en, large-v3
WHISPER_MODEL=base.en
WHISPER_MODEL_FILE=ggml-base.en.bin
WHISPER_MODEL_DIR=./whisper/models
WHISPER_MODEL_URL=

# Network settings
WHISPER_HOST=127.0.0.1
WHISPER_PORT=8080

# Runtime settings
WHISPER_SERVER_ARGS=

# launchd service settings (macOS)
# Keep this label stable once installed.
WHISPER_LAUNCHD_LABEL=io.local.whisper.runtime.server
WHISPER_LAUNCHD_PLIST=~/Library/LaunchAgents/io.local.whisper.runtime.server.plist
WHISPER_LAUNCHD_RUN_AT_LOAD=1
WHISPER_LAUNCHD_KEEP_ALIVE=1
WHISPER_STDOUT_LOG=./whisper/whisper-server.log
WHISPER_STDERR_LOG=./whisper/whisper-server.error.log
